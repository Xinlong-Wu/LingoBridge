# LingoBridge configuration
# Copy this file to ~/.lingobridge/config.yaml and fill in your values.
#   cp config.yaml.example ~/.lingobridge/config.yaml

llm:
  # Default model profile used for users without a model preference.
  default_model: "deepseek"

  # Named model profiles. Each profile is independent.
  # endpoint is optional and defaults to "chat".
  models:
    deepseek:
      provider: "openai"
      base_url: "https://api.deepseek.com/v1"
      api_key: "sk-your-api-key-here"
      id: "deepseek-chat"

    gpt4o:
      provider: "openai"
      base_url: "https://api.openai.com/v1"
      api_key: "sk-your-openai-key-here"
      id: "gpt-4o"
      endpoint: "responses"
      context_window: 128000
      # Optional provider-native context compaction. OpenAI requires
      # endpoint: "responses"; Anthropic requires endpoint: "messages".
      compact:
        mode: auto
        threshold: 0.9
        instructions: "Preserve user preferences, durable facts, decisions, and open tasks."

    claude:
      provider: "anthropic"
      base_url: "https://api.anthropic.com"
      api_key: "sk-ant-your-key-here"
      id: "claude-sonnet-4-20250514"
      endpoint: "messages"
      context_window: 200000
      # Enable only for Anthropic models that currently support native compaction.
      compact:
        mode: false

  # System prompt sent to the LLM with every conversation.
  # Defaults to "You are a helpful assistant." if empty or omitted.
  system_prompt: "You are a helpful assistant. Reply concisely."

  # Maximum historical messages to send per request. 0 = no limit (send all).
  # Default: 0
  max_history: 0

mcp:
  # Optional global MCP servers exposed as tools to tool-capable LLM profiles.
  # Tool names are registered as mcp_<server>_<tool>, for example
  # mcp_filesystem_read_file.
  servers:
    filesystem:
      transport: "stdio"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
      env: {}
      cwd: ""
      # Optional scope. Omit scope to expose the server to all bot accounts.
      # scope:
      #   platforms: ["feishu"]
      #   accounts:
      #     - "feishu/fsbot"     # platform/account name
      #     - "feishu:cli_xxx"   # stable account ID

    remote_docs:
      enabled: false
      transport: "streamable_http"
      url: "https://example.com/mcp"
      headers:
        Authorization: "Bearer your-token"

platforms:
  # Each platform owns the schema under platforms.<platform>.
  feishu:
    accounts:
      fsbot:
        app_id: "cli_xxx"
        app_secret: "your-app-secret"
        # Optional. Defaults to https://open.feishu.cn.
        base_url: "https://open.feishu.cn"

    # Optional event shell hooks for Feishu events other than
    # im.message.receive_v1, which is always handled by LingoBridge.
    # version is required: "1.0" uses OnCustomizedEvent; "2.0" uses a
    # built-in SDK OnP2... mapping.
    # Each command runs with event details in LINGOBRIDGE_* env vars.
    # Non-empty stdout is sent back only when the event contains a chat_id.
    events:
      - name: "p2p_chat_create"
        version: "1.0"
        run:
          - "printf '你好，我是 LingoBridge。直接发送问题即可开始对话。'"
          - "printf '%s' \"$LINGOBRIDGE_COMMAND_HELP\""

    # Optional platform tools exposed to tool-capable LLM model profiles.
    tools:
      max_results: 5
      max_chars: 12000
      allowed_folder_tokens: []
      allowed_space_ids: []
      docs:
        # Disabled by default. When enabled, the Feishu app's tenant access
        # token is used, so document visibility follows app permissions rather
        # than the asking user's personal permissions.
        enabled: false
        # Write tools are registered only when this is true and at least one
        # allowed_folder_tokens entry is configured.
        allow_write: false

      litellm:
        # Disabled by default. When enabled, tool-capable models can create a
        # LiteLLM user invitation from natural language after the user provides
        # both an email and application reason.
        enabled: false
        # LiteLLM proxy base URL. Invitation links are returned as:
        #   <base_url>/ui?invitation_id=<id>
        base_url: "https://litellm.example"
        # LiteLLM admin/master API key. Do not share this value in chat.
        api_key: "sk-litellm-admin-key"
        # Optional. Defaults to "internal_user".
        user_role: "internal_user"
        bitable:
          # Target Bitable Base token and table ID. These are not Feishu app
          # credentials; API auth reuses platforms.feishu.accounts.<name>.
          app_token: "base_xxx"
          table_id: "tbl_xxx"
          # Required logical fields; defaults shown below.
          email_field: "邮箱"
          reason_field: "申请原因"
          # Person field receiving the Feishu user who sent the request.
          owner_field: "所有者"
